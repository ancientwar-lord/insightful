{
  "services": {
    "web": {
      "root": "./",
      "framework": "nextjs",
      "bindings": [
        {
          "type": "service",
          "service": "api",
          "format": "url",
          "env": "BACKEND_INTERNAL_URL"
        }
      ]
    },
    "api": {
      "root": "./",
      "entrypoint": "news_agent/main.py",
      "framework": "fastapi"
    }
  },
  "rewrites": [
    {
      "source": "/agent",
      "destination": { "service": "api" }
    },
    {
      "source": "/agent/(.*)",
      "destination": { "service": "api" }
    },
    {
      "source": "/(.*)",
      "destination": { "service": "web" }
    }
  ]
}